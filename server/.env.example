# =============================================================================
# VPN Server — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then start:
#   docker compose up -d
# =============================================================================

# REQUIRED: URL to fetch VPN configs from (subscription link)
SUBSCRIPTION_URL=

# DuckDNS token for belirofon-vpn.duckdns.org (auto-updates server IP + SSL)
# Get it at https://www.duckdns.org
DUCK_DNS_TOKEN=

# Domain for HTTPS (used by Caddy reverse proxy + client builds)
DOMAIN=belirofon-vpn.duckdns.org

# Server listen address (internal, accessed via Caddy)
LISTEN_ADDR=:8080

# How often to refresh the config cache (default 30m)
REFRESH_INTERVAL=30m

# Ping timeout per config (default 5s)
PING_TIMEOUT=5s

# Path to GeoLite2-Country.mmdb (optional, without it RU filtering is disabled)
GEOIP_DB_PATH=/app/GeoLite2-Country.mmdb

# Set to "true" to use mock configs instead of SUBSCRIPTION_URL (for testing)
MOCK_CONFIGS=false

# Set to "false" to enforce TLS certificate verification (proxy testing)
SKIP_VERIFY_TLS=true

# CORS allowed origins ("*" for all, or specific origin like https://example.com)
CORS_ORIGINS=*

# Swagger docs host (domain + port, e.g. "belirofon-vpn.duckdns.org:8443")
# If empty, the host field is omitted from swagger.json
SWAGGER_HOST=belirofon-vpn.duckdns.org:8443

# Path to persist best configs JSON file (empty = no persistence)
# BEST_CONFIGS_PATH=/app/data/best_configs.json

# Admin panel credentials (used by Flutter client admin login)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=your-password
